{
    "swagger": "2.0",
    "info": {
        "description": "API for generating and listing analytics reports.",
        "title": "Analytics Service API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/analytics-service",
    "paths": {
        "/reports": {
            "get": {
                "description": "Returns all generated analytics reports.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reports"
                ],
                "summary": "List reports",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Maximum number of items to return; 0 means no limit",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Number of items to skip",
                        "name": "offset",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/analytics-service_service_analytics.Report"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/reports/basic/{periodStart}/{periodEnd}": {
            "post": {
                "description": "Generates a basic analytics report for the inclusive date period.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "reports"
                ],
                "summary": "Create basic report",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Period start date in YYYY-MM-DD format",
                        "name": "periodStart",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Period end date in YYYY-MM-DD format",
                        "name": "periodEnd",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/analytics-service_service_analytics.Report"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "analytics-service_service_analytics.Report": {
            "type": "object",
            "properties": {
                "CreatedAt": {
                    "type": "string"
                },
                "Files": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/file.File"
                    }
                },
                "ID": {
                    "type": "integer"
                },
                "PeriodEnd": {
                    "type": "string"
                },
                "PeriodStart": {
                    "type": "string"
                },
                "Type": {
                    "$ref": "#/definitions/analytics.ReportType"
                }
            }
        },
        "analytics.ReportType": {
            "type": "integer",
            "enum": [
                0,
                1
            ],
            "x-enum-varnames": [
                "ReportTypeUnknown",
                "ReportTypeBasic"
            ]
        },
        "file.Bucket": {
            "type": "string",
            "enum": [
                "images",
                "documents"
            ],
            "x-enum-varnames": [
                "BucketImages",
                "BucketDocuments"
            ]
        },
        "file.File": {
            "type": "object",
            "properties": {
                "Bucket": {
                    "$ref": "#/definitions/file.Bucket"
                },
                "FileName": {
                    "type": "string"
                },
                "FileSize": {
                    "type": "integer"
                },
                "ID": {
                    "type": "integer"
                },
                "URL": {
                    "type": "string"
                }
            }
        },
        "gorouter.ErrorInfo": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "gorouter.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/gorouter.ErrorInfo"
                }
            }
        }
    }
}